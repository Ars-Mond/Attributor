# Tauri bundle outputs — track large binaries via LFS
src-tauri/target/release/bundle/**/*.exe filter=lfs diff=lfs merge=lfs -text
src-tauri/target/release/bundle/**/*.msi filter=lfs diff=lfs merge=lfs -text
src-tauri/target/release/bundle/**/*.dmg filter=lfs diff=lfs merge=lfs -text
src-tauri/target/release/bundle/**/*.app filter=lfs diff=lfs merge=lfs -text
src-tauri/target/release/bundle/**/*.AppImage filter=lfs diff=lfs merge=lfs -text
src-tauri/target/release/bundle/**/*.deb filter=lfs diff=lfs merge=lfs -text
src-tauri/target/release/bundle/**/*.rpm filter=lfs diff=lfs merge=lfs -text

# App icons
src-tauri/icons/*.png filter=lfs diff=lfs merge=lfs -text
src-tauri/icons/*.ico filter=lfs diff=lfs merge=lfs -text
src-tauri/icons/*.icns filter=lfs diff=lfs merge=lfs -text

# General binary assets
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text
*.webp filter=lfs diff=lfs merge=lfs -text
*.ico filter=lfs diff=lfs merge=lfs -text
*.icns filter=lfs diff=lfs merge=lfs -text

# Line endings
* text=auto eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
