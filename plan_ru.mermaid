flowchart TD

    %% ── Внешний узел ───────────────────────────────────────────
    n22["Attributor"]

    %% ── Загрузка данных ─────────────────────────────────────────
    subgraph s3["Загрузка данных"]
        A["Открыть диалог"]
        A1["Читать папку"]
        n23["Читать путь файла (фотографии)"]
        n24["Сохрать в память (Это будет и так в FolderProcessor)"]
    end

    %% ── Чтение файла ────────────────────────────────────────────
    subgraph s2r["Чтение файла"]
        A3r["Есть ли кеш? (SQLite)"]
        B1["Хеш файл совпадает с кешем? (хеш — sha256 файла + mtime)"]
        B2["Читать из кеша"]
        D1["Читать метаданные"]
        D2["Записать в кеш"]
        n21["Вернуть значение"]
        n25["Есть ли данные в кеше?"]
        n26["Читать метаданные"]
        n27["Совпадают ли данные?"]
        n28["Обновить хеш в кеше"]
        n29["Спросить"]
        n30["Что было изменено последним?"]
        n31["Обновить кеш"]
        n32["Есть ли выбор для всех уже?"]
        n33["Выполнить по выбору"]
    end

    %% ── Импорт CSV ──────────────────────────────────────────────
    subgraph s1i["Импорт CSV"]
        n7i["Читать CSV"]
        A2["Читать путь файла"]
        n18["Есть ли такой файл?"]
        n16["Изменен ли файл?"]
        n17["Обновление файла"]
        n19["Записать во временный буфер пропущенный файл"]
        n20["Есть ли данные в кеше?"]
        n9i["Есть ли выбор для всех уже?"]
        n2i["Спросить о выборе"]
        n8i["Установить для всех выбор"]
        n10i["Выполнить по выбору"]
        n4i["Читать метаданные из обоих мест"]
        n5i["Читать метаданные из CSV"]
        n6i["Читать метаданные из кеша"]
        C3["Обновить кеш"]
        n11i["Есть ли следующий путь?"]
        n12i["Выбрать следующий путь"]
        n13i["Конец"]
    end

    %% ── Экспорт в CSV ───────────────────────────────────────────
    subgraph s1e["Экспорт в CSV"]
        A3e["Читать путь папки"]
        n1e["Читать список шаблонов CSV"]
        n2e["Читать шаблон"]
        n3e["Заполнить метаданные в CSV"]
        n4e["Сохранить CSV"]
        n5e["Есть следующий шаблон?"]
        n6e["Выбрать следующий шаблон"]
        n7e["Сообщить о конце экспорта"]
        n8e["Выход"]
        n11e["Читать все метаданные"]
    end

    %% ── Экспорт в Метаданные ────────────────────────────────────
    subgraph s2e["Экспорт в Метаданные"]
        n9e["Читать путь папки"]
        n10e["Читать все метаданные для папки"]
        n12e["Заполнить метаданные в фото"]
        n13e["Сохранить фото"]
        n14e["Обновить хеш в кеше"]
        n15e["Есть ли следующие фото?"]
        n16e["Выбрать следующие фото"]
        n17e["Сообщить о конце экспорта"]
        n18e["Конец"]
    end

    %% ── Связи: Загрузка данных (s3) ─────────────────────────────
    A   --> A1
    A1  --> n23
    n23 --> n24

    %% ── Связи: Чтение файла (s2r) ────────────────────────────────
    A3r -- Да  --> B1
    A3r -- Нет --> D1
    B1  -- Да  --> B2
    B1  -- Нет --> n26
    D1  --> D2
    B2  --> n21
    D2  --> n21
    n26 --> n25
    n25 -- Да  --> n32
    n25 -- Нет --> D2
    n27 -- Да  --> n28
    n28 --> B2
    n27 -- Нет --> n29
    n29 -- По времени    --> n30
    n29 -- Из метаданных --> n31
    n29 -- Из кеша       --> B2
    n30 -- Метаданные    --> n31
    n30 -- Кеш           --> B2
    n31 --> n21
    n32 -- Да  --> n33
    n32 -- Нет --> n27
    n33 --> n31 & n30 & B2

    %% ── Связи: Импорт CSV (s1i) ──────────────────────────────────
    n7i  --> A2
    A2   --> n18
    n18  -- Да  --> n16
    n18  -- Нет --> n19
    n16  -- Да  --> n17
    n16  -- Нет --> n20
    n17  --> n20
    n19  --> n11i
    n20  -- Да  --> n9i
    n20  -- Нет --> C3
    n9i  -- Нет --> n2i
    n9i  -- Да  --> n10i
    n2i  -- Да/Нет     --> n8i
    n2i  -- Объединить --> n4i
    n2i  -- Из CSV     --> n5i
    n2i  -- Из кеша    --> n6i
    n8i  --> n2i
    n10i --> n4i & n5i & n6i
    n4i  --> C3
    n5i  --> C3
    n6i  --> C3
    C3   --> n11i
    n11i -- Да  --> n12i
    n11i -- Нет --> n13i
    n12i --> A2

    %% ── Связи: Экспорт в CSV (s1e) ───────────────────────────────
    A3e  --> n11e
    n11e --> n1e
    n1e  --> n2e
    n2e  --> n3e
    n3e  --> n4e
    n4e  --> n5e
    n5e  -- Да  --> n6e
    n5e  -- Нет --> n7e
    n6e  --> n2e
    n7e  --> n8e

    %% ── Связи: Экспорт в Метаданные (s2e) ───────────────────────
    n9e  --> n10e
    n10e --> n12e
    n12e --> n13e
    n13e --> n14e
    n14e --> n15e
    n15e -- Да  --> n16e
    n15e -- Нет --> n17e
    n16e --> n12e
    n17e --> n18e

    %% ── Связи: Между subgraph ────────────────────────────────────
    n17  <-.->                       s2r
    n23  <-.->                       s2r
    n22  -. Импортировать из CSV  .-> s1i
    n22  -. Открыть папку         .-> s3
    n22  -. Экспортировать в CSV  .-> s1e
    n22  -. Экспорт в метаданные  .-> s2e

